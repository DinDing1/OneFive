#!/bin/bash

# 壹伍（OneFive）主启动脚本
# 飞牛OS会调用此脚本管理应用运行状态

case $1 in
start)
  # Socket 文件放在 target 目录（应用安装目录）
  SOCKET_PATH="${TRIM_APPDEST}/onefive.sock"
  
  # 清理旧的 socket 文件
  rm -f "${SOCKET_PATH}"
  
  # 设置环境变量
  export TRIM_PKGVAR="${TRIM_PKGVAR}"
  export ONEFIVE_SOCKET="${SOCKET_PATH}"
  
  # 启动后端服务
  cd "${TRIM_APPDEST}/app/server"
  nohup ./onefive-server > "${TRIM_PKGVAR}/logs/onefive.log" 2>&1 &
  
  # 等待服务启动
  sleep 2
  
  # 检查服务是否启动成功
  if [ -S "${SOCKET_PATH}" ]; then
    echo "壹伍服务启动成功"
    exit 0
  else
    echo "壹伍服务启动失败：Unix Socket 未创建" > "${TRIM_TEMP_LOGFILE}"
    exit 1
  fi
  ;;
stop)
  # 停止应用
  pkill -f "onefive-server"
  
  # 清理 socket 文件
  SOCKET_PATH="${TRIM_APPDEST}/onefive.sock"
  rm -f "${SOCKET_PATH}"
  
  echo "壹伍服务已停止"
  exit 0
  ;;
status)
  # 检查应用是否在运行
  if pgrep -f "onefive-server" > /dev/null; then
    exit 0
  else
    exit 3
  fi
  ;;
*)
  exit 1
  ;;
esac
